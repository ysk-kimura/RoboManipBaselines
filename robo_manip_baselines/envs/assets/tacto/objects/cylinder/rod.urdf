<?xml version="1.0"?>
<robot name="rod">

  <link name="rod">
    <visual>
      <geometry>
        <cylinder radius="0.006" length="0.30"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.2 0.2 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.0058" length="0.30"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

</robot>
